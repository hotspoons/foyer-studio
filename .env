# Foyer Studio — project-level environment defaults.
#
# Loaded by:
#   * scripts/dev/ardour.sh + scripts/bootstrap-workspace.sh
#     (sourced before reading vars; existing process-env wins)
#   * .github/workflows/{ci,release}.yml ("Load .env" step writes
#     these into $GITHUB_ENV so cache keys / matrix expressions see
#     the same values CI uses locally)
#
# Per-developer overrides live in `.env.local` (gitignored). Shell
# env always wins, so `ARDOUR_TAG=master just run` is also fine.

# Ardour git ref the shim is built against. Tags are major.minor
# only (`9.2`, not `9.2.0`). Branch (`master`) and commit SHA also
# accepted. ABI compatibility with the user's installed Ardour
# matters for shipped artifacts, so production tracks release tags;
# bump to `master` only while developing against post-tag APIs.
ARDOUR_TAG=9.2
